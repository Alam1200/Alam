rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Helpers
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check - bootstrap current user as admin
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'nadimalam1203@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // 1. User Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'plan', 'credits', 'createdAt']) &&
               data.keys().size() <= 7 &&
               data.uid == request.auth.uid &&
               data.email is string && data.email.size() <= 100 &&
               data.plan in ['free', 'pro', 'business'] &&
               data.credits is number && data.credits >= 0 &&
               data.createdAt == request.time;
      }
      
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isEmailVerified() && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && (
        // Prevent self-elevation of credits/plan for non-admins
        (isAdmin() && isValidUser(incoming())) ||
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']))
      );
    }

    // 2. Project Rules
    match /projects/{projectId} {
      function isValidProject(data) {
        return data.keys().hasAll(['id', 'userId', 'status', 'createdAt']) &&
               data.keys().size() <= 12 &&
               data.userId == request.auth.uid &&
               data.status in ['uploading', 'pending', 'processing', 'completed', 'failed'] &&
               data.createdAt == request.time &&
               isValidId(data.id);
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isEmailVerified() && isValidProject(incoming());
      
      allow update: if isSignedIn() && (
        (existing().userId == request.auth.uid || isAdmin()) &&
        (
          // Action: Rename
          (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt']) && incoming().updatedAt == request.time) ||
          // Action: Process (System update simulated by client for now, or admin)
          (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'progress', 'processedVideoUrl', 'updatedAt'])) ||
          // Action: Manual area selection
          (incoming().diff(existing()).affectedKeys().hasOnly(['subtitleRegions', 'updatedAt']) && incoming().updatedAt == request.time)
        )
      );
      
      allow delete: if (existing().userId == request.auth.uid || isAdmin());
    }

    // 3. Blog Rules
    match /blog/{postId} {
      function isValidBlogPost(data) {
        return data.keys().hasAll(['slug', 'title', 'content', 'publishedAt']) &&
               data.title is string && data.title.size() <= 200 &&
               data.slug is string && data.slug.size() <= 100;
      }

      allow read: if true; // Public blog
      allow write: if isAdmin();
    }
  }
}
